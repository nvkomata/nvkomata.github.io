---
import Layout from '../layouts/Layout.astro';
import Link from '../components/Link.astro';
---

<Layout title="nu:site">
	<main>
		<img class="bg" src="/background.png">
		<img class="title" src="/title.png">
		<ul role="list">
			<Link
				href="https://ko-fi.com/nuleftus"
				text="support me on [ko-fi] ❤️"
			/>
			<Link
				href="https://www.youtube.com/@nuleftus"
				text="my content on [youtube]"
			/>
			<Link
				href="https://www.last.fm/user/nvkomimi"
				text="i listen on [last.fm]"
			/>
		</ul>
	</main>
</Layout>

<style>
	main {
		margin: auto;
		padding: 1rem;
		max-width: 800px;
		color: white;
		font-size: 20px;
		line-height: 1.6;
		display: flex;
		justify-content: center;
		align-items: center;
		flex-direction: column;
	}
	img.bg {
		max-width: 100%;
	}
	img.title {
		max-width: 30%;
	}
	[role="list"] {
		padding: 0;
		margin: 0;
	}
</style>
