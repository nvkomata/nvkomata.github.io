---
import Layout from '../layouts/Layout.astro';
import Link from '../components/Link.astro';
---

<Layout title="nu:404">
	<main>
		<img src="/404.png" alt="404" class="title">
		<Link
			href="/"
			text="go back"
		/>
	</main>
</Layout>

<style>
	body {
		margin: 0;
		padding: 0;
		background: 
			linear-gradient( rgba(0,0,0,.7), rgba(0,0,0,.7) ), 
			no-repeat center/cover url('poster.gif');
	}
	main {
		margin: auto;
		padding: 0 1rem;
		height: 100vh;
		color: white;
		font-size: 1.5em;
		line-height: 1.6;
		display: flex;
		justify-content: center;
		align-items: center;
		flex-direction: column;
		user-select: none;
		filter: invert();
	}
	main>img {
		width: 15em;
		margin-bottom: 1em;
	}
</style>
