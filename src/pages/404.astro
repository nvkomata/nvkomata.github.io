---
import Layout from '../layouts/Layout.astro';
import Link from '../components/Link.astro';
---

<Layout title="nu:404">
	<main>
		<img src="/404.png" alt="404" class="title">
		<ul role="list">
			<Link
				href="/"
				text="go back"
			/>
		</ul>
	</main>
</Layout>

<style>
	main {
		margin: auto;
		padding: 1rem;
		max-width: 800px;
		color: white;
		font-size: 20px;
		line-height: 1.6;
		display: flex;
		justify-content: center;
		align-items: center;
		flex-direction: column;
	}
	img.bg {
		max-width: 100%;
	}
	img.title {
		max-width: 30%;
	}
	[role="list"] {
		padding: 0;
		margin: 0;
	}
</style>
