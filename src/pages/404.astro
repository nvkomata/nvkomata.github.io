---
import Layout from '../layouts/Layout.astro';
import Link from '../components/Link.astro';
---

<Layout title="nu:404">
	<main>
		<img src="/404.png" alt="404" class="title">
		<Link
			href="/"
			text="go back"
		/>
	</main>
</Layout>

<style>
	body {
		margin: 0;
		padding: 0;
	}
	main {
		margin: auto;
		padding: 0 1rem;
		max-width: 800px;
		height: 90vh;
		color: white;
		font-size: 1.5em;
		line-height: 1.6;
		display: flex;
		justify-content: center;
		align-items: center;
		flex-direction: column;
		user-select: none;
		filter: invert();
	}
	main>img {
		width: 15em;
		margin-bottom: 1em;
	}
</style>
