---
interface Props {
	text: string;
	href: string;
}

const { href, text } = Astro.props;
---

<a href={href}>
	{text}
</a>
<style>
	a {
		padding: 0;
		user-select: none;
		display: inline-block;
		padding: 1.5em;
		color: black;
		text-decoration: none;
		font-weight: bold;
		transition: all 0.1s ease-out;
		border-radius: 0 0 0 1.5em;
		box-shadow: inset 5px 0 15px rgba(111, 111, 111, 0.101);
		border-right: 0.5em solid rgba(158, 139, 143, 0.1);
		margin: 0.3em;
	}
	a:hover {
		background-color: black;
		color: white;
		border-right: 0.5em solid white;
	}
	@media only screen and (max-width: 900px) {
  		a {
			display: block;
		}
	}
</style>
