---
interface Props {
	text: string;
	href: string;
}

const { href, text } = Astro.props;
---

<li class="link">
	<a href={href}>
		{text}
	</a>
</li>
<style>
	.link {
		list-style: none;
		margin: 2em 0;
		padding: 0;
		user-select: none;
	}
	a {
		padding: 1.5em;
		color: black;
		text-decoration: none;
		font-weight: bold;
	}
	a:hover {
		background-color: black;
		color: white;
	}
</style>
